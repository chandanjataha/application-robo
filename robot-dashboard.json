{
  "title": "Robot Sensor Monitor",
  "uid":   "robot-sensor-monitor",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "gauge", "title": "CPU Temperature (°C)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "celsius",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 55 },
            { "color": "red",    "value": 75 }
          ]}
        }
      },
      "targets": [{ "expr": "robot_sensor_temperature_celsius", "legendFormat": "Temperature" }]
    },
    {
      "id": 2, "type": "gauge", "title": "Battery Level (%)",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red",    "value": null },
            { "color": "yellow", "value": 20 },
            { "color": "green",  "value": 50 }
          ]}
        }
      },
      "targets": [{ "expr": "robot_battery_level_percent", "legendFormat": "Battery" }]
    },
    {
      "id": 3, "type": "timeseries", "title": "Robot Velocity (m/s)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "velocityms" } },
      "targets": [{ "expr": "robot_velocity_ms", "legendFormat": "Velocity" }]
    },
    {
      "id": 4, "type": "timeseries", "title": "HTTP Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [{ "expr": "rate(http_requests_total[1m])", "legendFormat": "{{path}} {{status}}" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Request Latency P95 (ms)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95 {{path}}" }]
    },
    {
      "id": 6, "type": "stat", "title": "ROS2 Messages Published",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "targets": [{ "expr": "robot_ros2_messages_total", "legendFormat": "Messages" }]
    },
    {
      "id": 7, "type": "stat", "title": "Uptime",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "robot_uptime_seconds", "legendFormat": "Uptime" }]
    },
    {
      "id": 8, "type": "logs", "title": "Application Logs (Loki)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": "Loki",
      "targets": [{ "expr": "{job=\"robot-sensor-monitor\"}" }]
    }
  ]
}
